# Local dev config for docker-compose. Copy to .env and adjust as needed;
# compose falls back to these same defaults when .env is absent.
POSTGRES_USER=invoicing
POSTGRES_PASSWORD=invoicing
POSTGRES_DB=invoicing
DB_PORT=5432
APP_PORT=8080
WEB_PORT=5173

# The api reads DATABASE_URL, PORT, and NODE_ENV (validated in apps/api/src/config.ts).
# docker-compose derives DATABASE_URL and PORT for the app container from the values above;
# set DATABASE_URL yourself when running the api outside compose.

# QUICKBOOKS_CLIENT_ID/SECRET come from the Intuit developer app; in deployed environments
# they are injected as env vars from Secret Manager, not committed here. Leaving any of
# CLIENT_ID/CLIENT_SECRET/REDIRECT_URI unset disables the integration (config.qbo is null,
# apps/api/src/routes/integrations.ts:/connect and /callback return 503 qbo_not_configured).
QUICKBOOKS_APP_ID=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:8080/api/integrations/qbo/callback
QUICKBOOKS_ENVIRONMENT=sandbox

# Intuit app -> Webhooks -> Verifier Token (a distinct secret from CLIENT_SECRET above), used to
# verify the `intuit-signature` header on inbound webhook calls (apps/api/src/routes/qbo-webhook.ts).
# In deployed environments injected from Secret Manager. Unset leaves the webhook route failing
# closed (503 qbo_webhook_not_configured) rather than accepting unsigned calls.
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=

# Shared secret gating POST /internal/retry-sweep (apps/api/src/routes/internal.ts), the endpoint
# Cloud Scheduler calls in place of the in-process retry-sweep timer on Cloud Run. Unset locally
# disables the endpoint (503 sweep_not_configured); in deployed environments it's injected from
# Secret Manager and must match the value Cloud Scheduler sends as the X-Sweep-Token header.
SYNC_SWEEP_TOKEN=

# Session auth (apps/api/src/config.ts). SESSION_SECRET signs the session cookie;
# set a long random value in real environments. SESSION_TTL_HOURS defaults to 168 (7 days).
SESSION_SECRET=dev-only-change-me
SESSION_TTL_HOURS=168

# Dev-only seed users created by `pnpm --filter @invoicing/api db:seed`
# (admin@invoicing.test / member@invoicing.test); defaults to "password123" if unset.
SEED_ADMIN_PASSWORD=password123
SEED_MEMBER_PASSWORD=password123


GCP_PROJECT_ID=clearbooks-501812