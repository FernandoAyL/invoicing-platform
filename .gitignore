CLAUDE.local.md
init.md
node_modules/
.env

# Vite build output (apps/web)
apps/web/dist/
apps/web/dist-ssr/

# CI test report artifact (generated on the runner)
test-report.junit.xml

# Agent pipeline runtime state (churns per task); definitions stay tracked
.claude/agents/state.json
.claude/plans/

# Terraform local state + provider cache (infra/terraform, infra/bootstrap);
# .terraform.lock.hcl stays tracked in each stack's directory
infra/*/.terraform/
infra/*/terraform.tfstate*
infra/*/*.tfvars
infra/*/*.tfplan
