{
  "name": "@invoicing/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --disable-warning=ExperimentalWarning src/index.ts",
    "start": "node --disable-warning=ExperimentalWarning src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --disable-warning=ExperimentalWarning src/db/migrate.ts",
    "db:seed": "node --disable-warning=ExperimentalWarning src/db/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.9.0",
    "fastify-plugin": "^6.0.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
