{
  "name": "invoicing-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24.12"
  },
  "scripts": {
    "dev": "pnpm --filter @invoicing/api dev",
    "start": "pnpm --filter @invoicing/api start",
    "typecheck": "pnpm -r typecheck",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "ci": "biome ci .",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2"
  }
}
