{
  "name": "invoicing-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24.12"
  },
  "scripts": {
    "dev": "node --watch --disable-warning=ExperimentalWarning src/index.ts",
    "start": "node --disable-warning=ExperimentalWarning src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "ci": "biome ci ."
  },
  "dependencies": {
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.2"
  }
}
